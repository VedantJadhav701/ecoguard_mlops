# Environment Configuration for EcoGuard

# Application Settings
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# FastAPI Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# MLflow Configuration
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_REGISTRY_URI=http://mlflow:5000

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ecoguard
DB_USER=ecoguard
DB_PASSWORD=ecoguard_dev

# Model Configuration
MODEL_VERSION=latest
MODEL_CONFIDENCE_THRESHOLD=0.5
MAX_MODEL_SIZE_MB=500

# Monitoring
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s

# Storage Paths
MODELS_PATH=/app/models
LOGS_PATH=/app/logs
ARTIFACTS_PATH=/app/mlruns

# Feature Flags
ENABLE_ADVANCED_METRICS=true
ENABLE_MODEL_EXPLANATIONS=false
ENABLE_BATCH_PREDICTIONS=true

# Security
SECRET_KEY=your-secret-key-change-in-production
API_KEY_HEADER=X-API-Key

# Training/Validation Settings
TEST_SIZE=0.2
RANDOM_STATE=42
